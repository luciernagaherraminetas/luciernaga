@app.route("/crear-checkout", methods=["POST"])
def crear_checkout():

    data = request.json

    fotos = data.get("seleccionadas", [])
    email = data.get("email")
    evento = data.get("evento")

    if not fotos:
        return jsonify(error="Datos incompletos"), 400

    albums = load_albums()

    if evento not in albums:
        return jsonify(error="Evento inválido"), 400

    precio = albums[evento].get("precio", 100)

    try:

        session = stripe.checkout.Session.create(

            payment_method_types=["card"],

            line_items=[{
                "price_data": {
                    "currency": "mxn",
                    "product_data": {
                        "name": "Fotos del evento",
                    },
                    "unit_amount": int(precio * 100),
                },
                "quantity": len(fotos),
            }],

            mode="payment",

            success_url="https://app.luciernaga.site/gracias-stripe?session_id={CHECKOUT_SESSION_ID}",
            cancel_url="https://app.luciernaga.site/",

            metadata={
                "fotos": ",".join(fotos),
                "email": email or "",
                "evento": evento
            }
        )

        return jsonify(url=session.url)

    except Exception as e:

        print("Stripe error:", e)

        return jsonify(error="Error creando sesión de pago"), 500

