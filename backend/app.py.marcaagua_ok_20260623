@app.route("/admin/notificaciones")
@admin_required
def admin_notificaciones():

    archivo = "data/subscriptions.json"

    try:
        with open(archivo, "r") as f:
            subs = json.load(f)
    except:
        subs = []

    iphone = 0
    android = 0
    desktop = 0

    for s in subs:

        ua = s.get("user_agent", "")

        if "iPhone" in ua:
            iphone += 1

        elif "Android" in ua:
            android += 1

        else:
            desktop += 1

    stats_file = "data/notificaciones_stats.json"

    try:
        with open(stats_file, "r") as f:
            stats = json.load(f)
    except:
        stats = {
            "enviadas": 0,
            "abiertas": 0
        }

    return render_template(
        "admin_notificaciones.html",
        total=len(subs),
        iphone=iphone,
        android=android,
        desktop=desktop,
        enviadas=stats["enviadas"],
        abiertas=stats["abiertas"]
    )
