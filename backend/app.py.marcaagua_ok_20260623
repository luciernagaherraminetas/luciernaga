@admin_required
def delete_album(slug):

    albums = load_albums()

    if slug not in albums:
        return ("", 204)

    # 1️⃣ borrar carpeta del álbum
    album_path = os.path.join(BASE_ALBUMS_PATH, slug)

    if os.path.exists(album_path):
       shutil.rmtree(album_path)

    # 2️⃣ borrar rostros del álbum
    rostros_path = os.path.join(ROSTROS_PATH, f"{slug}.json")

    if os.path.exists(rostros_path):
        os.remove(rostros_path)

    # 3️⃣ eliminar del panel
    del albums[slug]
    save_albums(albums)

    return redirect("/admin/albums")

