@app.route("/buscar-dorsal/<dorsal>")
def buscar_dorsal(dorsal):
    albums = load_albums()
    activo = next((k for k, v in albums.items() if v.get("activo")), None)
    if not activo:
        return jsonify(fotos=[])

    preview_path = os.path.join(BASE_ALBUMS_PATH, activo, "preview")
    if not os.path.exists(preview_path):
        return jsonify(fotos=[])

    fotos = [f for f in os.listdir(preview_path) if f.startswith(dorsal)]
    return jsonify(fotos=fotos)

@app.route("/descargar/<token>")
def descargar(token):

    pago = Pago.query.filter_by(token=token).first()

    if not pago:
        return "Enlace inválido", 404

    if pago.expira < int(time.time()):
        return "Enlace expirado", 403
    nombre_evento = pago.evento

    if not nombre_evento:
        return "Evento no asociado al pago", 500

    memory_file = io.BytesIO()

    with zipfile.ZipFile(memory_file, "w") as zf:
        for foto in pago.fotos:
            ruta = os.path.join(
                BASE_ALBUMS_PATH,
                nombre_evento,
                "originales",
                foto
            )

            if os.path.exists(ruta):
                zf.write(ruta, foto)

    memory_file.seek(0)

    pago.descargado = True
    db.session.commit()

    return send_file(
        memory_file,
        as_attachment=True,
        download_name="fotos.zip",
        mimetype="application/zip"
    )

@app.route("/gracias-stripe")
def gracias_stripe():
    import secrets
    import time
    import json

    session_id = request.args.get("session_id")

    if not session_id:
        return "Pago inválido"

    session = stripe.checkout.Session.retrieve(session_id)

    if session.payment_status != "paid":
        return "Pago aún procesándose..."

    # Buscar si ya existe el pago
    pago = Pago.query.filter_by(payment_id=session_id).first()

    if not pago:

        fotos_raw = session.metadata.get("fotos", "")
        email = session.metadata.get("email", "")

        fotos_lista = fotos_raw.split(",") if fotos_raw else []
        fotos_json = json.loads(json.dumps(fotos_lista))

        token = secrets.token_urlsafe(32)

        albums = load_albums()
        activo = next((k for k, v in albums.items() if v.get("activo")), None)

        nuevo_pago = Pago(
            payment_id=session_id,
            email=email,
            fotos=fotos_json,
            token=token,
            evento=activo,
            expira=int(time.time()) + 86400,
            descargado=False,
            created_at=int(time.time())
        )

        db.session.add(nuevo_pago)
        db.session.commit()

        pago = nuevo_pago

    return render_template(
        "gracias.html",
        fotos=len(pago.fotos),
        token=pago.token
    )
