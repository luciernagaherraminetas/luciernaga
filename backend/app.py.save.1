@app.route("/admin/albums")
@admin_required
def admin_albums():

    albums = load_albums()
    pagos = Pago.query.all()

    resumen_ventas = {}

    for slug in albums.keys():
        resumen_ventas[slug] = {
            "fotos_vendidas": 0,
            "total_dinero": 0
        }

    for p in pagos:
        if p.evento in resumen_ventas:
            cantidad = len(p.fotos or [])
            resumen_ventas[p.evento]["fotos_vendidas"] += cantidad
            resumen_ventas[p.evento]["total_dinero"] += cantidad * PRECIO_FOTO

    return render_template(
        "admin_albums_dashboard.html",
        albums=albums,
        resumen_ventas=resumen_ventas
    )

