@app.route("/crear-checkout", methods=["POST"])
def crear_checkout():
    data = request.json
    fotos = data.get("seleccionadas", [])
    email = data.get("email")

    if not fotos or not email:
        return jsonify(error="Datos incompletos"), 400

    try:
        # Crear sesión en Stripe
        session = stripe.checkout.Session.create(
            payment_method_types=["card"],
            line_items=[{
                "price_data": {
                    "currency": "mxn",
                    "product_data": {
                        "name": "Fotos del evento",
                    },
                     albums = load_albums()
                     activo = next((k for k,v in albums.items() if v.get("activo")), None)
                     precio = albums[activo].get("precio",100)

                     unit_amount": int(precio * 100),
                },
                "quantity": len(fotos),
            }],
            mode="payment",
            success_url="https://app.luciernaga.site/gracias-stripe?session_id={CHECKOUT_SESSION_ID}",
            cancel_url="https://app.luciernaga.site/",
            metadata={
                "fotos": ",".join(fotos),
                "email": email
            }
        )

        print("Stripe session created successfully:", session)  # Depuración

        return jsonify(url=session.url)

    except Exception as e:
        print("Error creating Stripe session:", e)  # Depuración
        return jsonify(error="Error creando sesión de pago"), 500

@app.route("/webhook", methods=["POST"])
def webhook():
